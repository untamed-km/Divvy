{
  "functions": {
    "api/advisor.js": {
      "maxDuration": 30
    },
    "api/create-checkout-session.js": {
      "maxDuration": 10
    },
    "api/stripe-webhook.js": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
    },
    {
      "source": "/index.html",
      "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
    },
    {
      "source": "/",
      "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
    },
    {
      "source": "/admin",
      "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
    },
    {
      "source": "/admin.html",
      "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
    }
  ]
}
